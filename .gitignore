# Node
node_modules/
dist/
build/

# Python
venv/
.venv/
__pycache__/
*.pyc

# Environment
.env
.env.*
!.env.example
backend/.env
frontend/.env
frontend/.env.local

# IDE
.vscode/
.idea/

