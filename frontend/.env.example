# ============================================
# Agrow AI Frontend — Environment Configuration
# Copy this file to .env and adjust if needed.
# Optional: the app works with the default below for local dev.
# ============================================

# Base URL the frontend calls for the backend API.
# Local dev default already matches this - only needed to override
# (e.g. pointing at a deployed backend).
VITE_API_URL=http://localhost:5000/api
