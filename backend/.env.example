# ============================================
# Agrow AI Backend — Environment Configuration
# Copy this file to .env and fill in real values.
# Never commit the real .env file.
# ============================================

# --- Server ---
PORT=5000
NODE_ENV=development
# development | production | test

# --- Database ---
# Local dev example: mongodb://localhost:27017/agrow-ai
# MongoDB Atlas example: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/agrow-ai
MONGO_URI=mongodb://localhost:27017/agrow-ai

# --- Auth ---
# Generate a strong secret with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRE=7d

# --- AI Forecast microservice (FastAPI, ml/app.py) ---
ML_SERVICE_URL=http://127.0.0.1:8000

# --- File storage ---
REPORT_STORAGE_PATH=./uploads/reports

# --- Logging (Module 3) ---
# error | warn | info | http | debug
LOG_LEVEL=info

# --- CORS (Module 1 / Module 9) ---
# The frontend origin(s) allowed to call this API. Comma-separate multiple
# origins (e.g. a Vercel preview + production URL).
# Local dev default: http://localhost:5173
CLIENT_URL=http://localhost:5173
